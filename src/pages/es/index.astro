---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PostIndex from '../../components/PostIndex.astro';
import { t, routes } from '../../i18n/ui';

const tr = t('es');

const posts = (await getCollection('blog', ({ id, data }) => id.startsWith('es/') && !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
---

<Base
  lang="es"
  altUrl="/"
  title="José Luis Alba · Ingeniero de datos"
  description="Ingeniero de datos senior en Panamá. Desde 2013: SAP BW a nivel regional, migración del DW de Riesgo por cambio de core, IFRS 9 en PySpark. Escribo las decisiones que tomo construyendo."
>
  <section class="hero wrap">
    <p class="eyebrow">Ingeniero de datos senior · Panamá · UTC-5</p>

    <h1>Construyo pipelines que sobreviven al contacto con <em>la operación</em>.</h1>

    <p class="hero__dek">
      Desde 2013, casi siempre donde un número mal tiene consecuencias: un retail saliendo a la
      región, un banco cambiando su core. Hoy también lo hago en producto propio. Acá escribo las
      decisiones: los números detrás, lo que cedí, y lo que se rompió igual.
    </p>

    <p class="hero__avail">
      Abierto a roles remotos de ingeniería de datos senior. Panamá está en UTC-5 — overlap
      completo con US Eastern, sin visa requerida, sin teatro de zonas horarias.
    </p>
  </section>

  <section class="stack wrap">
    <div class="stack__row">
      <span class="stack__label">Ingesta y transformación</span>
      <span class="stack__items">BigQuery · dbt · Python · PySpark</span>
    </div>
    <div class="stack__row">
      <span class="stack__label">Gobierno y calidad</span>
      <span class="stack__items">DAMA/DMBOK · Linaje · Contratos de datos</span>
    </div>
    <div class="stack__row">
      <span class="stack__label">Dominio</span>
      <span class="stack__items">Banca · Seguros · Reportería regulatoria</span>
    </div>
  </section>

  <section class="wrap latest">
    <div class="latest__head">
      <h2 class="latest__title">{tr('blog.latest')}</h2>
      <a href={routes.blog('es')} class="latest__more">{tr('blog.all')}</a>
    </div>
    <PostIndex posts={posts} lang="es" />
  </section>
</Base>

<style>
  .hero {
    padding-block: clamp(4rem, 12vw, 8rem) clamp(3rem, 8vw, 5rem);
  }

  .eyebrow {
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.14em;
    color: var(--orange);
    margin: 0 0 28px;
  }

  h1 {
    font-family: var(--display);
    font-weight: 700;
    font-size: clamp(2.25rem, 5vw, 4rem);
    line-height: 1.04;
    letter-spacing: -0.025em;
    margin: 0;
    max-width: 19ch;
    text-wrap: balance;
  }

  h1 em {
    font-style: normal;
    color: var(--orange);
  }

  .hero__dek {
    font-size: clamp(1.0625rem, 2vw, 1.3125rem);
    line-height: 1.55;
    color: var(--ink-70);
    max-width: 58ch;
    margin: 2rem 0 0;
  }

  .hero__avail {
    font-family: var(--mono);
    font-size: 0.8125rem;
    line-height: 1.7;
    color: var(--ink-70);
    max-width: 52ch;
    margin: 2rem 0 0;
    padding-left: 0.9rem;
    border-left: 2px solid var(--orange);
  }

  .stack {
    border-top: 1px solid var(--ink);
    border-bottom: 1px solid var(--ink);
    padding-block: 4px;
  }

  .stack__row {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 8px 40px;
    padding: 20px 0;
  }

  .stack__row + .stack__row {
    border-top: 1px solid var(--rule);
  }

  .stack__label {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-40);
  }

  .stack__items {
    font-family: var(--mono);
    font-size: 14px;
    color: var(--ink);
  }

  .latest {
    padding-block: clamp(3rem, 6vw, 4.5rem);
  }

  .latest__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 12px;
  }

  .latest__title {
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink);
    margin: 0;
  }

  .latest__more {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--ink-55);
  }

  @media (max-width: 640px) {
    .stack__row {
      grid-template-columns: 1fr;
      gap: 6px;
    }
  }
</style>
