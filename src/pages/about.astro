---
import Base from '../layouts/Base.astro';
---

<Base
  lang="en"
  altUrl="/es/sobre-mi/"
  title="About · José Luis Alba"
  description="Senior data engineer based in Panama City, open to full-time remote roles — full overlap with US Eastern hours."
  activeNav="about"
>
  <section class="wrap page">
    <h1>What I'm looking for</h1>

    <div class="prose">
      <p>
        A full-time remote role as a senior data engineer. I'm based in Panama City — UTC-5, so I
        fully overlap with US Eastern hours, and there's no visa or relocation to sort out. If
        you're hiring, <a href="/contact/">let's talk</a> or find me on
        <a href="https://www.linkedin.com/in/joseluisalba/" target="_blank" rel="noopener">LinkedIn</a>.
      </p>
    </div>
  </section>
</Base>

<style>
  .page {
    padding-block: clamp(3rem, 6vw, 4.5rem);
    max-width: 760px;
  }

  h1 {
    font-family: var(--display);
    font-weight: 700;
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.02em;
    margin: 0 0 32px;
  }

  .prose {
    font-size: 1.125rem;
    line-height: 1.65;
    color: var(--ink-80);
  }

  .prose p {
    margin: 0;
  }

  .prose a {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
