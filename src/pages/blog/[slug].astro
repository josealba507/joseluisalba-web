---
import { getCollection, type CollectionEntry } from 'astro:content';
import Post from '../../layouts/Post.astro';
import { postUrl, routes } from '../../i18n/ui';

export async function getStaticPaths() {
  const posts = await getCollection(
    'blog',
    ({ id, data }) => id.startsWith('en/') && (!data.draft || !import.meta.env.PROD)
  );
  return posts.map((entry) => ({ params: { slug: entry.slug.slice(3) }, props: { entry } }));
}

interface Props {
  entry: CollectionEntry<'blog'>;
}

const { entry } = Astro.props;

const sameType = (await getCollection('blog', ({ id, data }) => id.startsWith('en/') && !data.draft))
  .filter((p) => p.data.eyebrow === entry.data.eyebrow)
  .sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());

const currentIndex = sameType.findIndex((p) => p.id === entry.id);
const number = currentIndex === -1 ? sameType.length + 1 : currentIndex + 1;
const next = currentIndex >= 0 ? sameType[currentIndex + 1] : undefined;
const nextPost = next ? { title: next.data.title, url: postUrl('en', next.slug) } : null;

let translatedPostUrl: string | null = null;
if (entry.data.translationKey) {
  const esMatch = (await getCollection('blog', ({ id }) => id.startsWith('es/'))).find(
    (p) => p.data.translationKey === entry.data.translationKey
  );
  if (esMatch) translatedPostUrl = postUrl('es', esMatch.slug);
}

const altUrl = translatedPostUrl ?? routes.blog('es');
---

<Post entry={entry} lang="en" altUrl={altUrl} number={number} translatedPostUrl={translatedPostUrl} nextPost={nextPost} />
